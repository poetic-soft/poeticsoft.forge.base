{
	"folders": [
    {
      "path": "."
    }
  ],
  "settings": {
    "emeraldwalk.runonsave": {
      "autoClearConsole": true,
      "commands": [
        {
          "match": ".*", 
          "isShellCommand": true,
            "cmd": "powershell -Command \"$wshell = New-Object -ComObject WScript.Shell; if (false && $wshell.AppActivate('Chrome')) { Start-Sleep -Milliseconds 250; $wshell.SendKeys('{F5}') }\""
        }
      ]
    }
  }
}