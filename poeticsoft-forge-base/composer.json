{
  "name": "poeticsoft/forge-base",
  "description": "Base module for Poeticsoft Forge ecosystem",
  "type": "wordpress-plugin",
  "version": "0.0.0",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Poeticsoft Team",
      "email": "alberto@poeticsoft.com"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "autoload": {
    "psr-4": {
      "Poeticsoft\\": "class/"
    }
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^4.0"
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "scripts": {
    "make-pot": "vendor\\bin\\wp.bat i18n make-pot . languages/poeticsoft-forge-base.pot --exclude=vendor",  
    "format": "phpcbf .",
    "lint": "phpcs .",
    "fix": [
        "@format",
        "@lint"
    ],
    "estructura": "php tools\\estructura.php",
    "plugin": "php tools\\plugin.php",
    "doc": [
        "@estructura",
        "@plugin"
    ],
    "fixdoc": [
        "@fix",
        "@doc"
    ]
  }
}